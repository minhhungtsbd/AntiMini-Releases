SYNC_TOKEN=secret-sync-token
APP_SECRET=antimini-app-secret-key-2026-secure

PORT=12342
S3_ENDPOINT=http://localhost:8987
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=antimini-sync
S3_FORCE_PATH_STYLE=true

# Redis stores profile-device leases durably across NestJS restarts.
# Keep it on localhost for a self-hosted server.
REDIS_URL=redis://127.0.0.1:6379
